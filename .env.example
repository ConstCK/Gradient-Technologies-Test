# Локальный запуск (python main.py) — обязателен DATABASE_URL с localhost
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/gradient_test

# Docker Compose — подставляются в postgres и в DATABASE_URL контейнера app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=gradient

DEBUG=True
LOG_LEVEL=INFO
